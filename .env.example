# Local dev env. Copy to .env: `cp .env.example .env`
# Session cookie encryption key (min 32 chars). Generate a random one for production.
NUXT_SESSION_PASSWORD=dev-only-password-change-me-32chars-min

# Nome da app (default "Maurício"). Ajustável sem mexer no código.
# NUXT_PUBLIC_APP_NAME=Maurício

# Assistente de chat (Ollama) — opcional; tem defaults em nuxt.config.
# OLLAMA_BASE_URL=http://192.168.1.203:11434
# OLLAMA_MODEL=minimax-m3:cloud

# Do NOT set LAR_DB_PATH in dev — that is container-only (Docker volume).
# In dev the database lives at server/db/lar.sqlite.
